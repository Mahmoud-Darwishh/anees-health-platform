// ============================================================================
// DOCTORS — Bilingual provider profiles (migrated from JSON)
// ============================================================================

model Doctor {
  id                    Int      @id
  slug                  String   @unique
  image                 String
  rating                Float
  gender                String
  location              String
  experienceYears       Int
  successRate           String
  avgWaitTime           String
  totalPatients         String
  availabilityStatus    String
  availabilityBadgeClass String
  specialityColorClass  String
  specialityTextClass   String
  duration              String
  channels              Json
  languages             Json
  clinics               Json
  areaCoverage          Json
  clinicDetails         Json
  testimonials          Json
  workHistory           Json?

  // Pricing (stored as strings to match existing format e.g. "EGP 1500" / "N/A")
  priceTelemedicine     String
  priceHomeVisit        String
  priceClinicVisit      String
  consultationFee       String
  maxConsultationFee    String

  // English content
  nameEn                String
  specialityEn          String
  professionalTitleEn   String
  bioEn                 String?
  certificationsEn      Json
  educationEn           Json

  // Arabic content
  nameAr                String
  specialityAr          String
  professionalTitleAr   String
  bioAr                 String?
  certificationsAr      Json
  educationAr           Json

  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([slug])
  @@index([specialityEn])
  @@index([isActive])
  @@map("doctors")
}

// ============================================================================
// AUDIT LOG — Full history of every record change
// ============================================================================

model AuditLog {
  id            String      @id @default(cuid())
  tableName     String
  recordId      String
  action        AuditAction
  changedFields Json?
  previousData  Json?
  newData       Json?
  changedBy     String?
  changedAt     DateTime    @default(now())

  @@index([tableName, recordId])
  @@index([changedAt])
  @@index([changedBy])
  @@map("audit_logs")
}

// ============================================================================
// BOOKING PRICES — All service prices editable from DB (no code deploy needed)
// ============================================================================

model BookingPrice {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "telemedicine", "homeVisit:doctorVisit"
  label     String           // Human-readable for admin display
  priceEgp  Int
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("booking_prices")
}

// ============================================================================
// SPECIALTIES — Medical specialties with bilingual names
// ============================================================================

model Specialty {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "geriatrics", "cardiology"
  nameEn    String
  nameAr    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  @@index([isActive, sortOrder])
  @@map("specialties")
}

// ============================================================================
// CONTENT SERVICES — Services shown on the /services marketing page
// ============================================================================

model ContentService {
  id          String   @id @default(cuid())
  code        String   @unique // matches translation key, e.g. "doctorVisits"
  iconClass   String           // e.g. "isax isax-health"
  landingSlug String?          // e.g. "doctor-at-home" — null if no landing page
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  @@map("content_services")
}

// ============================================================================
// RATE LIMIT — Fixed-window counters backing the rate-limit helper
// ============================================================================

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "booking-create:1.2.3.4"
  count       Int      @default(0)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@map("rate_limits")
}

// ============================================================================
// COVERAGE CHECK — Every map/form coverage query for analytics
// ============================================================================

model CoverageCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  latitude  Float
  longitude Float
  covered   Boolean
  areaName  String?
  ipHash    String?  // SHA-256 prefix of visitor IP — no PII stored
  userAgent String?

  @@index([createdAt])
  @@index([covered])
  @@index([areaName])
  @@map("coverage_checks")
}

// ============================================================================
// AUTH — NextAuth v5 (Auth.js). User is the auth identity.
//   - role=patient → links to Patient record via patientId
//   - role=staff   → links to Staff record via staffId
// JWT strategy: no Session table needed. Account is for OAuth only.
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(patient)
  patientId     String?   @unique
  staffId       String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient  Patient? @relation(fields: [patientId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])
  accounts Account[]

  @@index([role])
  @@index([phone])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
