generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum VisitStatus {
  scheduled
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum VisitType {
  in_home
  telemedicine
}

enum PatientGender {
  M
  F
  other
}

enum PatientStatus {
  new
  active
  lapsed
  inactive
}

enum FamilyStatus {
  active
  inactive
}

enum ProviderStatus {
  active
  inactive
  on_leave
}

enum ProviderPaymentType {
  per_visit
  package
  salary
  commission
}

enum ServiceStatus {
  active
  inactive
  discontinued
}

enum CarePlanStatus {
  active
  completed
  cancelled
}

enum InvoiceStatus {
  issued
  partial
  paid
  overdue
  cancelled
}

enum InvoiceLinkedType {
  visit
  care_plan
}

enum OnlineBookingStatus {
  pending
  payment_pending
  payment_completed
  payment_failed
  refunded
  confirmed
  cancelled
  converted
}

enum OnlineVisitType {
  homeVisit
  telemedicine
  package
}

enum OnlineServiceType {
  doctorVisit
  physiotherapy
  nursing
}

enum OnlinePackageType {
  haraka
  wai
  amal
  sanad
}

enum StaffRole {
  superadmin
  admin
  medical_ops
  operator
  doctor
  physiotherapist
  nurse
  insurance_coordinator
  compliance_officer
  hospital_partner_admin
  finance
  viewer
}

enum StaffStatus {
  active
  inactive
  suspended
}

enum TenantStatus {
  active
  suspended
  archived
}

enum LicenseType {
  medical_syndicate
  nursing_syndicate
  physiotherapy_syndicate
  pharmacy_syndicate
  none
}

enum Locale {
  en
  ar
}

enum AuditAction {
  create
  update
  delete
  read
  override
  export
  access_denied
  login
  logout
}

enum UserRole {
  patient
  staff
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum MaritalStatus {
  single
  married
  divorced
  widowed
  separated
  other
}

enum DnrStatus {
  full_code
  dnr
  unknown
}

enum NurseShiftAssignmentStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum CoverageStatus {
  active
  inactive
  expired
  suspended
}

enum PriorAuthStatus {
  draft
  submitted
  approved
  denied
  expired
}

enum ClaimStatus {
  draft
  submitted
  adjudicating
  paid
  partially_paid
  denied
  cancelled
}

enum ClaimLineStatus {
  pending
  approved
  denied
}

enum ControlledSubstanceAction {
  prescribed
  administered
  reconciled
  wasted
}

// ============================================================================
// PHYSIO WORKSPACE — visit state machine, goals, profile
// See docs/EHR_PHYSIO_SPEC.md for the spec these enums implement.
// ============================================================================

enum VisitState {
  draft
  scheduled
  acknowledged
  declined_by_physio
  cancelled_by_patient
  cancelled_by_med_ops
  reassigned_to_other_physio
  en_route
  diverted_in_transit
  arrived
  refused_at_door
  patient_not_home
  checked_in
  documenting
  session_interrupted
  rescheduled_in_place
  signed
  amended
  checked_out
  completed
  disputed
  force_closed_by_admin
  abandoned
}

enum VisitDisruptionCode {
  patient_late_cancel
  patient_no_show
  patient_refused_care
  patient_hospitalised
  patient_deceased
  family_blocked_access
  unsafe_environment
  physio_personal_emergency
  physio_vehicle_breakdown
  physio_traffic_blocked
  weather
  med_ops_reassignment
  equipment_failure
  internet_blackout
  other
}

enum PhysioOnboardingState {
  invited
  documents_pending
  documents_submitted
  interview_scheduled
  trial_visit_scheduled
  approved
  suspended
  off_boarded
}

enum GoalStatus {
  in_progress
  met
  discontinued
}

enum VisitParticipantRole {
  primary_clinician
  secondary_clinician
  observer
  trainer
  trainee
  family_witness
}

enum TrialVisitOutcome {
  pending
  passed
  failed
  needs_re_trial
}

// ============================================================================
// LOOKUP TABLES
// ============================================================================

model Area {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  governorate   String
  serviceActive Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  families  Family[]
  patients  Patient[]
  providers Provider[]
  visits    Visit[]

  @@map("areas")
}

model ServiceCategory {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  defaultProviderRole String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  services Service[]

  @@map("service_categories")
}

model ProviderRole {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers Provider[]
  services  Service[]

  @@map("provider_roles")
}

model PaymentMethod {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments        Payment[]
  expenses        Expense[]
  providerPayouts ProviderPayout[]

  @@map("payment_methods")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@map("expense_categories")
}

model ReferralSource {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  channelType String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patients Patient[]

  @@map("referral_sources")
}

model Tenant {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  contactEmail String?
  status       TenantStatus @default(active)
  isPlatform   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@map("tenants")
}

// ============================================================================
// CORE TABLES
// ============================================================================

model Family {
  id                  String       @id @default(cuid())
  code                String       @unique
  name                String?
  primaryContactName  String?
  primaryContactPhone String?
  relationToPatients  String?
  areaId              String?
  registrationDate    DateTime     @db.Date
  status              FamilyStatus @default(active)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  area     Area?     @relation(fields: [areaId], references: [id])
  patients Patient[]

  @@index([areaId])
  @@index([status])
  @@map("families")
}

model Patient {
  id               String        @id @default(cuid())
  code             String        @unique
  familyId         String?
  fullName         String
  arabicName       String?
  phone            String
  gender           PatientGender?
  dateOfBirth      DateTime?     @db.Date
  nationalId       String?
  passportNumber   String?
  bloodGroup       BloodGroup?
  maritalStatus    MaritalStatus?
  preferredLanguage Locale?
  religion         String?
  occupation       String?
  insuranceProvider String?
  insuranceMemberId String?
  insurancePolicyNumber String?
  insuranceExpiry  DateTime?     @db.Date
  dnrStatus        DnrStatus?
  areaId           String?
  addressDetail    String?
  landmark         String?
  gpsLatitude      Decimal?      @db.Decimal(10, 7)
  gpsLongitude     Decimal?      @db.Decimal(10, 7)
  addressMapUrl    String?
  handoffGeofenceRadiusMeters Int?
  addressVerifiedAt           DateTime?  // First-visit address-truth ritual (Sprint 0)
  addressFidelity             String?    // 'precise' | 'approximate' | 'rural' — drives override leniency
  safetyFlags                 Json?      // string[] e.g. ['aggressive_dog','unsafe_stairs','infection_isolation']
  privacyTier                 String?    @default("standard") // 'standard' | 'enhanced' | 'restricted'
  temporarilyAwayUntil DateTime?
  temporarilyAwayNote String?
  temporarilyAwayAddress String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyContactRelation String?
  registrationDate DateTime      @db.Date @default(now())
  primaryCaregiver String?
  primaryCaregiverPhone String?
  primaryCaregiverWhatsapp String?
  primaryCaregiverEmail String?
  caregiverRelation String?
  chiefComplaint   String?
  referralSourceId String?
  status           PatientStatus @default(new)
  notes            String?
  medplumPatientId String?       @unique
  tenantId         String        @default("platform")
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  family         Family?         @relation(fields: [familyId], references: [id])
  area           Area?           @relation(fields: [areaId], references: [id])
  referralSource ReferralSource? @relation(fields: [referralSourceId], references: [id])
  visits         Visit[]
  carePlans      CarePlan[]
  invoices       Invoice[]
  payments       Payment[]
  nurseShiftAssignments NurseShiftAssignment[]
  standingOrders StandingOrder[]
  coverages      Coverage[]
  priorAuths     PriorAuth[]
  claims         Claim[]
  controlledSubstanceLedgerEntries ControlledSubstanceLedger[]
  userAccount    User?
  goals          PatientGoal[]          @relation("PatientGoals")
  visitTransitionsAsActor VisitStateTransition[] @relation("VisitTransitionActorPatient")

  @@index([familyId])
  @@index([areaId])
  @@index([status])
  @@index([referralSourceId])
  @@index([phone])
  @@index([tenantId])
  @@index([deletedAt])
  @@index([nationalId])
  @@index([passportNumber])
  @@map("patients")
}

model Provider {
  id            String              @id @default(cuid())
  code          String              @unique
  fullName      String
  roleId        String
  specialty     String?
  phone         String?
  email         String?
  joiningDate   DateTime            @db.Date
  paymentType   ProviderPaymentType @default(per_visit)
  baseRateEgp   Decimal             @db.Decimal(10, 2)
  commissionPct Decimal?            @db.Decimal(5, 2)
  primaryAreaId String?
  status        ProviderStatus      @default(active)
  notes         String?
  tenantId      String              @default("platform")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  role            ProviderRole     @relation(fields: [roleId], references: [id])
  primaryArea     Area?            @relation(fields: [primaryAreaId], references: [id])
  linkedStaff     Staff?           @relation("StaffProviderLink")
  visits          Visit[]
  providerPayouts ProviderPayout[]
  expenses        Expense[]

  @@index([roleId])
  @@index([status])
  @@index([tenantId])
  @@index([primaryAreaId])
  @@map("providers")
}

model Service {
  id                       String        @id @default(cuid())
  code                     String        @unique
  name                     String
  categoryId               String
  requiredRoleId           String?
  durationMins             Int
  listPriceEgp             Decimal       @db.Decimal(10, 2)
  defaultProviderPayoutEgp Decimal       @db.Decimal(10, 2)
  description              String?
  status                   ServiceStatus @default(active)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  category     ServiceCategory @relation(fields: [categoryId], references: [id])
  requiredRole ProviderRole?   @relation(fields: [requiredRoleId], references: [id])
  visits       Visit[]

  @@index([categoryId])
  @@index([status])
  @@map("services")
}

model Visit {
  id                String      @id @default(cuid())
  code              String      @unique
  patientId         String
  providerId        String?
  serviceId         String
  carePlanId        String?
  bookedDate        DateTime    @db.Date
  scheduledDate     DateTime    @db.Date
  scheduledTime     String?
  completedDatetime DateTime?
  durationActualMin Int?
  status            VisitStatus @default(scheduled)
  areaId            String?
  visitType         VisitType   @default(in_home)
  servicePriceEgp   Decimal     @db.Decimal(10, 2)
  discountEgp       Decimal     @db.Decimal(10, 2) @default(0)
  netPriceEgp       Decimal     @db.Decimal(10, 2)
  providerPayoutEgp Decimal     @db.Decimal(10, 2)
  patientRating     Int?
  bookedBy          String?
  notes             String?
  acknowledgedAt    DateTime?
  enRouteAt         DateTime?
  arrivedAt         DateTime?
  checkInAt         DateTime?
  checkInLat        Decimal?    @db.Decimal(10, 7)
  checkInLng        Decimal?    @db.Decimal(10, 7)
  checkInAccuracyM  Int?
  checkOutAt        DateTime?
  checkOutLat       Decimal?    @db.Decimal(10, 7)
  checkOutLng       Decimal?    @db.Decimal(10, 7)
  checkOutAccuracyM Int?
  // ── New state machine + check-in protocol fields (Sprint 0) ──
  state                    VisitState? @default(scheduled)
  identityConfirmedBy      String?     // 'patient' | 'caregiver:{name}' | 'unable'
  consentReaffirmed        Boolean?
  safetyClearance          Boolean?
  companionsPresent        Json?       // string[] e.g. ['caregiver_primary','family_member']
  geofencePassed           Boolean?
  geofenceOverrideMethod   String?     // 'photo' | 'code' | 'med_ops' | null
  overridePhotoMediaId     String?     // FHIR Media id
  patientAcknowledgementMediaId String? // Signature image FHIR Media id
  cashGratuityEgp          Decimal?    @db.Decimal(10, 2)
  cashCollectedEgp         Decimal?    @db.Decimal(10, 2)
  receiptDeliveryChannels  Json?       // string[] e.g. ['whatsapp','print']
  primaryDisruptionCode    VisitDisruptionCode?
  // ── Tenant + audit ──
  tenantId          String      @default("platform")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id])
  provider      Provider?     @relation(fields: [providerId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
  carePlan      CarePlan?     @relation(fields: [carePlanId], references: [id])
  area          Area?         @relation(fields: [areaId], references: [id])
  invoices      Invoice[]
  expenses      Expense[]
  onlineBooking OnlineBooking?
  standingOrderExecutions StandingOrderExecution[]
  locationPings  VisitLocationPing[]
  claims         Claim[]
  controlledSubstanceLedgerEntries ControlledSubstanceLedger[]
  stateTransitions VisitStateTransition[]
  participants     VisitParticipant[]

  @@index([patientId])
  @@index([providerId])
  @@index([serviceId])
  @@index([status])
  @@index([state])
  @@index([tenantId])
  @@index([scheduledDate])
  @@index([areaId])
  @@index([carePlanId])
  @@map("visits")
}

model CarePlan {
  id                 String         @id @default(cuid())
  code               String         @unique
  patientId          String
  planName           String
  startDate          DateTime       @db.Date
  endDate            DateTime       @db.Date
  totalVisitsPlanned Int
  totalPriceEgp      Decimal        @db.Decimal(10, 2)
  status             CarePlanStatus @default(active)
  notes              String?
  tenantId           String         @default("platform")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  patient  Patient   @relation(fields: [patientId], references: [id])
  visits   Visit[]
  invoices Invoice[]

  @@index([patientId])
  @@index([status])
  @@index([tenantId])
  @@map("care_plans")
}

model Invoice {
  id               String            @id @default(cuid())
  code             String            @unique
  patientId        String
  invoiceDate      DateTime          @db.Date @default(now())
  linkedType       InvoiceLinkedType
  linkedVisitId    String?
  linkedCarePlanId String?
  grossAmountEgp   Decimal           @db.Decimal(10, 2)
  discountPct      Decimal           @db.Decimal(5, 2) @default(0)
  netAmountEgp     Decimal           @db.Decimal(10, 2)
  dueDate          DateTime?         @db.Date
  status           InvoiceStatus     @default(issued)
  notes            String?
  tenantId         String            @default("platform")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  patient        Patient    @relation(fields: [patientId], references: [id])
  linkedVisit    Visit?     @relation(fields: [linkedVisitId], references: [id])
  linkedCarePlan CarePlan?  @relation(fields: [linkedCarePlanId], references: [id])
  payments       Payment[]

  @@index([patientId])
  @@index([status])
  @@index([tenantId])
  @@index([dueDate])
  @@index([linkedVisitId])
  @@index([linkedCarePlanId])
  @@map("invoices")
}

model Payment {
  id              String   @id @default(cuid())
  code            String   @unique
  invoiceId       String
  patientId       String
  paymentDate     DateTime @db.Date @default(now())
  amountEgp       Decimal  @db.Decimal(10, 2)
  paymentMethodId String
  referenceNumber String?
  receivedBy      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  patient       Patient       @relation(fields: [patientId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([invoiceId])
  @@index([patientId])
  @@index([paymentDate])
  @@map("payments")
}

model Expense {
  id               String   @id @default(cuid())
  code             String   @unique
  expenseDate      DateTime @db.Date
  categoryId       String
  subcategory      String?
  vendorPayee      String?
  amountEgp        Decimal  @db.Decimal(10, 2)
  paymentMethodId  String?
  linkedVisitId    String?
  linkedProviderId String?
  receiptRef       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  linkedVisit     Visit?          @relation(fields: [linkedVisitId], references: [id])
  linkedProvider  Provider?       @relation(fields: [linkedProviderId], references: [id])

  @@index([categoryId])
  @@index([expenseDate])
  @@index([linkedVisitId])
  @@index([linkedProviderId])
  @@map("expenses")
}

model ProviderPayout {
  id              String   @id @default(cuid())
  code            String   @unique
  providerId      String
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  payoutDate      DateTime @db.Date
  totalVisits     Int
  grossAmountEgp  Decimal  @db.Decimal(10, 2)
  deductionsEgp   Decimal  @db.Decimal(10, 2) @default(0)
  netAmountEgp    Decimal  @db.Decimal(10, 2)
  paymentMethodId String?
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider      Provider       @relation(fields: [providerId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([providerId])
  @@index([payoutDate])
  @@map("provider_payouts")
}

// ============================================================================
// ONLINE BOOKING — Website funnel → converts to Visit
// ============================================================================

model OnlineBooking {
  id                   String              @id @default(cuid())
  bookingRef           String              @unique
  fullName             String
  countryCode          String
  phoneNumber          String
  visitType            OnlineVisitType
  serviceType          OnlineServiceType?
  specialty            String?
  packageType          OnlinePackageType?
  packageDuration      String?
  preferredDate        DateTime?           @db.Date
  timePreference       String?
  sessionCount         String?
  caseType             String?
  nursingType          String?
  nursingHoursPerDay   String?
  nursingDuration      String?
  baseAmountEgp        Decimal             @db.Decimal(10, 2) @default(0)
  discountEgp          Decimal             @db.Decimal(10, 2) @default(0)
  amountEgp            Decimal             @db.Decimal(10, 2)
  currency             String              @default("EGP")
  status               OnlineBookingStatus @default(pending)

  promocodeId          String?
  promocodeCode        String?
  promocode            Promocode?          @relation(fields: [promocodeId], references: [id])

  kashierSessionId     String?
  kashierOrderId       String?
  kashierTransactionId String?
  paymentCompletedAt   DateTime?

  confirmationSentAt   DateTime?

  convertedVisitId     String?  @unique
  convertedAt          DateTime?

  locale               Locale   @default(ar)
  tenantId             String   @default("platform")
  ipAddress            String?
  userAgent            String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  convertedVisit Visit? @relation(fields: [convertedVisitId], references: [id])

  @@index([bookingRef])
  @@index([status])
  @@index([tenantId])
  @@index([phoneNumber])
  @@index([createdAt])
  @@index([promocodeId])
  @@index([kashierTransactionId])
  @@index([kashierSessionId])
  @@index([kashierOrderId])
  @@map("online_bookings")
}

// ============================================================================
// PROMOCODES — Booking discount codes (% or fixed EGP)
// ============================================================================

enum PromocodeKind {
  percentage
  fixed
}

model Promocode {
  id              String        @id @default(cuid())
  code            String        @unique // Stored uppercase; lookups normalise input
  description     String?
  kind            PromocodeKind @default(percentage)
  /// When kind=percentage, value is 0-100. When kind=fixed, value is EGP.
  value           Decimal       @db.Decimal(10, 2)
  /// Optional minimum booking amount before discount applies (EGP).
  minAmountEgp    Decimal?      @db.Decimal(10, 2)
  /// Optional cap on the absolute discount applied (EGP).
  maxDiscountEgp  Decimal?      @db.Decimal(10, 2)
  /// Total redemption cap across all bookings. null = unlimited.
  maxRedemptions  Int?
  redeemedCount   Int           @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookings        OnlineBooking[]

  @@index([isActive, expiresAt])
  @@map("promocodes")
}

// ============================================================================
// PWA PUSH SUBSCRIPTIONS
// ============================================================================

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  locale    Locale   @default(ar)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale])
  @@map("push_subscriptions")
}

// ============================================================================
// STAFF — Admin dashboard users
// ============================================================================

model Staff {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  passwordHash String
  providerId  String?     @unique
  medplumPractitionerId String? @unique
  role        StaffRole   @default(viewer)
  status      StaffStatus @default(active)
  clinicalLicenseType   LicenseType?
  clinicalLicenseNumber String?
  clinicalLicenseExpiry DateTime?
  licenseIssuingBody    String?
  isOnCall              Boolean     @default(false)
  isClinicalDirector    Boolean     @default(false)
  tenantId              String      @default("platform")
  lastLoginAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  provider               Provider? @relation("StaffProviderLink", fields: [providerId], references: [id])
  primaryNurseAssignments NurseShiftAssignment[] @relation("PrimaryNurseAssignments")
  incomingNurseAssignments NurseShiftAssignment[] @relation("IncomingNurseAssignments")
  userAccount            User?
  // Physio workspace back-relations (Sprint 0)
  physioProfile          PhysioProfile? @relation("PhysioProfileStaff")
  trialVisitScorecardsAsPhysio TrialVisitScorecard[] @relation("TrialPhysio")
  trialVisitScorecardsAsScorer TrialVisitScorecard[] @relation("TrialScorer")
  visitStateTransitions  VisitStateTransition[] @relation("VisitTransitionActorStaff")
  visitParticipations    VisitParticipant[]     @relation("VisitParticipantStaff")
  authoredPatientGoals   PatientGoal[]          @relation("PatientGoalAuthor")

  @@index([email])
  @@index([role])
  @@index([tenantId])
  @@index([providerId])
  @@index([medplumPractitionerId])
  @@map("staff")
}

model NurseShiftAssignment {
  id                  String  @id @default(cuid())
  patientId           String
  primaryNurseStaffId String
  shiftStartAt        DateTime
  shiftEndAt          DateTime
  status              NurseShiftAssignmentStatus @default(scheduled)
  incomingNurseStaffId String?
  acknowledgedAt      DateTime?
  escalationTaskId    String?
  notes               String?
  createdByStaffId    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  patient        Patient @relation(fields: [patientId], references: [id])
  primaryNurse   Staff   @relation("PrimaryNurseAssignments", fields: [primaryNurseStaffId], references: [id])
  incomingNurse  Staff?  @relation("IncomingNurseAssignments", fields: [incomingNurseStaffId], references: [id])

  @@index([patientId, shiftStartAt])
  @@index([primaryNurseStaffId, shiftStartAt])
  @@index([incomingNurseStaffId, acknowledgedAt])
  @@index([escalationTaskId])
  @@map("nurse_shift_assignments")
}

// ============================================================================
// DOCTORS — Bilingual provider profiles (migrated from JSON)
// ============================================================================

model Doctor {
  id                    Int      @id
  slug                  String   @unique
  image                 String
  rating                Float
  gender                String
  location              String
  experienceYears       Int
  successRate           String
  avgWaitTime           String
  totalPatients         String
  availabilityStatus    String
  availabilityBadgeClass String
  specialityColorClass  String
  specialityTextClass   String
  duration              String
  channels              Json
  languages             Json
  clinics               Json
  areaCoverage          Json
  clinicDetails         Json
  testimonials          Json
  workHistory           Json?

  // Pricing (stored as strings to match existing format e.g. "EGP 1500" / "N/A")
  priceTelemedicine     String
  priceHomeVisit        String
  priceClinicVisit      String
  consultationFee       String
  maxConsultationFee    String

  // English content
  nameEn                String
  specialityEn          String
  professionalTitleEn   String
  bioEn                 String?
  certificationsEn      Json
  educationEn           Json

  // Arabic content
  nameAr                String
  specialityAr          String
  professionalTitleAr   String
  bioAr                 String?
  certificationsAr      Json
  educationAr           Json

  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([slug])
  @@index([specialityEn])
  @@index([isActive])
  @@map("doctors")
}

// ============================================================================
// AUDIT LOG — Full history of every record change
// ============================================================================

model AuditLog {
  id            String      @id @default(cuid())
  tableName     String
  recordId      String
  action        AuditAction
  changedFields Json?
  previousData  Json?
  newData       Json?
  changedBy     String?
  changedAt     DateTime    @default(now())

  @@index([tableName, recordId])
  @@index([tableName, recordId, changedAt])
  @@index([changedAt])
  @@index([changedBy])
  @@map("audit_logs")
}

model StandingOrder {
  id             String   @id @default(cuid())
  patientId      String
  discipline     String
  title          String
  instructions   String
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean  @default(true)
  createdByStaffId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient        Patient  @relation(fields: [patientId], references: [id])
  executions     StandingOrderExecution[]

  @@index([patientId, isActive])
  @@index([discipline])
  @@index([validUntil])
  @@map("standing_orders")
}

model StandingOrderExecution {
  id               String   @id @default(cuid())
  standingOrderId  String
  visitId          String?
  executedByStaffId String
  executedAt       DateTime @default(now())
  executionNote    String?
  createdAt        DateTime @default(now())

  standingOrder    StandingOrder @relation(fields: [standingOrderId], references: [id], onDelete: Cascade)
  visit            Visit?        @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([standingOrderId, executedAt])
  @@index([visitId])
  @@map("standing_order_executions")
}

model DestructiveApprovalToken {
  id              String   @id @default(cuid())
  medplumPatientId String
  actionType      String
  targetRecordId  String
  payload         Json?
  requestedBy     String
  approvedBy      String?
  approvedAt      DateTime?
  consumedBy      String?
  consumedAt      DateTime?
  expiresAt       DateTime
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([medplumPatientId, actionType, status])
  @@index([targetRecordId, actionType])
  @@index([expiresAt])
  @@map("destructive_approval_tokens")
}

model InsurerProfile {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  payerType         String?
  supportsDirectBilling Boolean @default(true)
  isActive          Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  coverages         Coverage[]
  priorAuths        PriorAuth[]
  claims            Claim[]

  @@index([isActive])
  @@map("insurer_profiles")
}

model Coverage {
  id               String         @id @default(cuid())
  patientId        String
  insurerProfileId String?
  memberId         String?
  policyNumber     String?
  planName         String?
  status           CoverageStatus @default(active)
  startsAt         DateTime?
  expiresAt        DateTime?
  metadata         Json?
  tenantId         String         @default("platform")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  patient          Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  insurerProfile   InsurerProfile? @relation(fields: [insurerProfileId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
  @@index([insurerProfileId])
  @@index([tenantId])
  @@map("coverages")
}

model PriorAuth {
  id               String          @id @default(cuid())
  patientId        String
  insurerProfileId String?
  referenceNumber  String?
  requestedFor     String?
  status           PriorAuthStatus @default(draft)
  submittedAt      DateTime?
  resolvedAt       DateTime?
  expiresAt        DateTime?
  notes            String?
  tenantId         String          @default("platform")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  insurerProfile   InsurerProfile? @relation(fields: [insurerProfileId], references: [id], onDelete: SetNull)
  claims           Claim[]

  @@index([patientId, status])
  @@index([insurerProfileId])
  @@index([tenantId])
  @@map("prior_auths")
}

model Claim {
  id               String      @id @default(cuid())
  code             String      @unique
  patientId        String
  visitId          String?
  insurerProfileId String?
  priorAuthId      String?
  status           ClaimStatus @default(draft)
  submittedAt      DateTime?
  adjudicatedAt    DateTime?
  totalAmountEgp   Decimal     @db.Decimal(10, 2)
  approvedAmountEgp Decimal?   @db.Decimal(10, 2)
  deniedReason     String?
  tenantId         String      @default("platform")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  patient          Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit            Visit?        @relation(fields: [visitId], references: [id], onDelete: SetNull)
  insurerProfile   InsurerProfile? @relation(fields: [insurerProfileId], references: [id], onDelete: SetNull)
  priorAuth        PriorAuth?    @relation(fields: [priorAuthId], references: [id], onDelete: SetNull)
  lineItems        ClaimLineItem[]

  @@index([patientId, status])
  @@index([visitId])
  @@index([insurerProfileId])
  @@index([priorAuthId])
  @@index([tenantId])
  @@map("claims")
}

model ClaimLineItem {
  id             String          @id @default(cuid())
  claimId        String
  serviceCode    String?
  description    String
  quantity       Int             @default(1)
  unitPriceEgp   Decimal         @db.Decimal(10, 2)
  amountEgp      Decimal         @db.Decimal(10, 2)
  status         ClaimLineStatus @default(pending)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  claim          Claim           @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([status])
  @@map("claim_line_items")
}

model VisitLocationPing {
  id              String   @id @default(cuid())
  visitId         String
  pingedAt        DateTime @default(now())
  latitude        Decimal  @db.Decimal(10, 7)
  longitude       Decimal  @db.Decimal(10, 7)
  accuracyMeters  Int?
  speedMetersPerSec Decimal? @db.Decimal(8, 3)
  headingDegrees  Decimal? @db.Decimal(6, 2)
  source          String?  // e.g. gps, network
  createdAt       DateTime @default(now())

  visit           Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId, pingedAt])
  @@map("visit_location_pings")
}

model ControlledSubstanceLedger {
  id                 String                     @id @default(cuid())
  patientId          String
  visitId            String?
  medicationName     String
  dosage             String?
  route              String?
  quantity           Decimal?                   @db.Decimal(10, 3)
  unit               String?
  actionType         ControlledSubstanceAction
  referenceNumber    String?
  recordedBy         String?
  notes              String?
  tenantId           String                     @default("platform")
  occurredAt         DateTime                   @default(now())
  createdAt          DateTime                   @default(now())

  patient            Patient                    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit              Visit?                     @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([patientId, occurredAt])
  @@index([visitId])
  @@index([tenantId])
  @@index([actionType])
  @@map("controlled_substance_ledger")
}

// ============================================================================
// BOOKING PRICES — All service prices editable from DB (no code deploy needed)
// ============================================================================

model BookingPrice {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "telemedicine", "homeVisit:doctorVisit"
  label     String           // Human-readable for admin display
  priceEgp  Int
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("booking_prices")
}

// ============================================================================
// SPECIALTIES — Medical specialties with bilingual names
// ============================================================================

model Specialty {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "geriatrics", "cardiology"
  nameEn    String
  nameAr    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  @@index([isActive, sortOrder])
  @@map("specialties")
}

// ============================================================================
// CONTENT SERVICES — Services shown on the /services marketing page
// ============================================================================

model ContentService {
  id          String   @id @default(cuid())
  code        String   @unique // matches translation key, e.g. "doctorVisits"
  iconClass   String           // e.g. "isax isax-health"
  landingSlug String?          // e.g. "doctor-at-home" — null if no landing page
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  @@map("content_services")
}

// ============================================================================
// RATE LIMIT — Fixed-window counters backing the rate-limit helper
// ============================================================================

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "booking-create:1.2.3.4"
  count       Int      @default(0)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@map("rate_limits")
}

// ============================================================================
// COVERAGE CHECK — Every map/form coverage query for analytics
// ============================================================================

model CoverageCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  latitude  Float
  longitude Float
  covered   Boolean
  areaName  String?
  ipHash    String?  // SHA-256 prefix of visitor IP — no PII stored
  userAgent String?

  @@index([createdAt])
  @@index([covered])
  @@index([areaName])
  @@map("coverage_checks")
}

// ============================================================================
// AUTH — NextAuth v5 (Auth.js). User is the auth identity.
//   - role=patient → links to Patient record via patientId
//   - role=staff   → links to Staff record via staffId
// JWT strategy: no Session table needed. Account is for OAuth only.
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(patient)
  patientId     String?   @unique
  staffId       String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient  Patient? @relation(fields: [patientId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])
  accounts Account[]

  @@index([role])
  @@index([phone])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// PHYSIO WORKSPACE — Sprint 0 models
// Spec: docs/EHR_PHYSIO_SPEC.md
// ============================================================================

/// One-to-one sidecar on Staff for physiotherapists.
model PhysioProfile {
  id                    String   @id @default(cuid())
  staffId               String   @unique
  // Identity & verification
  syndicateNumber       String?
  syndicateIssuedAt     DateTime?
  syndicateExpiresAt    DateTime?
  nationalId            String?
  passportNumber        String?
  yearsOfExperience     Int?
  // Education
  degree                String?
  graduationYear        Int?
  postGradQualifications Json?
  certifications        Json?
  // Practice
  specialties           Json?       // ["orthopedic","neuro","geriatric","pediatric","sports","respiratory","pelvic_floor","vestibular"]
  languages             Json?       // ["ar","en","fr"]
  yearsInHomeCare       Int?
  // Onboarding state
  onboardingState       PhysioOnboardingState @default(invited)
  documentsSubmittedAt  DateTime?
  interviewedAt         DateTime?
  trialVisitCompletedAt DateTime?
  approvedAt            DateTime?
  approvedByStaffId     String?
  // Operational
  primaryAreaCodes      Json?
  preferredVisitTimes   Json?
  maxVisitsPerDay       Int?
  canAcceptUrgent       Boolean  @default(true)
  // Public profile
  bioEn                 String?
  bioAr                 String?
  publicPhotoUrl        String?
  publicSlug            String?  @unique
  publicRating          Decimal? @db.Decimal(3, 2)
  publicReviewCount     Int      @default(0)
  publicVisitCount      Int      @default(0)
  isPublic              Boolean  @default(false)
  // Self-service
  acceptingNewPatients  Boolean  @default(true)
  outOfOfficeUntil      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  staff                 Staff    @relation("PhysioProfileStaff", fields: [staffId], references: [id])

  @@index([onboardingState])
  @@index([isPublic])
  @@map("physio_profiles")
}

/// Outcome record from a physio's trial (shadowed) visit during onboarding.
model TrialVisitScorecard {
  id                  String   @id @default(cuid())
  physioStaffId       String
  scorerStaffId       String
  scheduledAt         DateTime
  completedAt         DateTime?
  // 7-domain rubric (1–5)
  clinicalReasoning   Int?
  handsOnTechnique    Int?
  documentationCompleteness Int?
  patientRapport      Int?
  timeManagement      Int?
  safetyAdherence     Int?
  professionalism     Int?
  meanScore           Decimal? @db.Decimal(3, 2)
  minDomainScore      Int?
  outcome             TrialVisitOutcome @default(pending)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  physio              Staff @relation("TrialPhysio", fields: [physioStaffId], references: [id])
  scorer              Staff @relation("TrialScorer", fields: [scorerStaffId], references: [id])

  @@index([physioStaffId])
  @@index([scorerStaffId])
  @@index([outcome])
  @@map("trial_visit_scorecards")
}

/// Append-only ledger of every visit state change. Source of truth for the lifecycle.
model VisitStateTransition {
  id              String   @id @default(cuid())
  visitId         String
  fromState       VisitState?
  toState         VisitState
  actorStaffId    String?
  actorPatientId  String?
  actorSystem     Boolean  @default(false)
  reasonCode      VisitDisruptionCode?
  reasonNote      String?
  contextJson     Json?    // captured payload (identity confirmation, companions present, etc.)
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  accuracyMeters  Int?
  isOverride      Boolean  @default(false)
  overrideMethod  String?
  createdAt       DateTime @default(now())

  visit           Visit    @relation(fields: [visitId], references: [id])
  actorStaff      Staff?   @relation("VisitTransitionActorStaff", fields: [actorStaffId], references: [id])
  actorPatient    Patient? @relation("VisitTransitionActorPatient", fields: [actorPatientId], references: [id])

  @@index([visitId, createdAt])
  @@index([toState])
  @@index([actorStaffId])
  @@map("visit_state_transitions")
}

/// Multi-clinician participants for joint visits (physio + nurse, observer shadowing, etc.).
model VisitParticipant {
  id              String              @id @default(cuid())
  visitId         String
  staffId         String
  role            VisitParticipantRole @default(primary_clinician)
  joinedAt        DateTime?
  leftAt          DateTime?
  notes           String?
  createdAt       DateTime            @default(now())

  visit           Visit @relation(fields: [visitId], references: [id])
  staff           Staff @relation("VisitParticipantStaff", fields: [staffId], references: [id])

  @@unique([visitId, staffId])
  @@index([staffId])
  @@map("visit_participants")
}

/// SMART patient goal authored by a physio (or other clinician). Visualized on patient banner.
model PatientGoal {
  id              String   @id @default(cuid())
  fhirGoalId      String?  @unique @map("fhir_goal_id")
  patientId       String
  carePlanId      String?
  authorStaffId   String
  text            String
  category        String?  // 'mobility' | 'strength' | 'pain' | 'function' | 'endurance' | 'balance'
  baselineValue   String?
  currentValue    String?
  targetValue     String?
  measurementUnit String?
  targetDate      DateTime? @db.Date
  status          GoalStatus @default(in_progress)
  metAt           DateTime?
  discontinuedReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient @relation("PatientGoals", fields: [patientId], references: [id])
  author          Staff   @relation("PatientGoalAuthor", fields: [authorStaffId], references: [id])

  @@index([patientId, status])
  @@index([authorStaffId])
  @@map("patient_goals")
}
