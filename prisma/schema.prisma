generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum VisitStatus {
  scheduled
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum VisitType {
  in_home
  telemedicine
}

enum PatientGender {
  M
  F
  other
}

enum PatientStatus {
  new
  active
  lapsed
  inactive
}

enum FamilyStatus {
  active
  inactive
}

enum ProviderStatus {
  active
  inactive
  on_leave
}

enum ProviderPaymentType {
  per_visit
  package
  salary
  commission
}

enum ServiceStatus {
  active
  inactive
  discontinued
}

enum CarePlanStatus {
  active
  completed
  cancelled
}

enum InvoiceStatus {
  issued
  partial
  paid
  overdue
  cancelled
}

enum InvoiceLinkedType {
  visit
  care_plan
}

enum OnlineBookingStatus {
  pending
  payment_pending
  payment_completed
  payment_failed
  refunded
  confirmed
  cancelled
  converted
}

enum OnlineVisitType {
  homeVisit
  telemedicine
  package
}

enum OnlineServiceType {
  doctorVisit
  physiotherapy
  nursing
}

enum OnlinePackageType {
  haraka
  wai
  amal
  sanad
}

enum StaffRole {
  superadmin
  admin
  operator
  doctor
  physiotherapist
  nurse
  finance
  viewer
}

enum StaffStatus {
  active
  inactive
  suspended
}

enum Locale {
  en
  ar
}

enum AuditAction {
  create
  update
  delete
}

enum UserRole {
  patient
  staff
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum MaritalStatus {
  single
  married
  divorced
  widowed
  separated
  other
}

enum DnrStatus {
  full_code
  dnr
  unknown
}

enum NurseShiftAssignmentStatus {
  scheduled
  in_progress
  completed
  cancelled
}

// ============================================================================
// LOOKUP TABLES
// ============================================================================

model Area {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  governorate   String
  serviceActive Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  families  Family[]
  patients  Patient[]
  providers Provider[]
  visits    Visit[]

  @@map("areas")
}

model ServiceCategory {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  defaultProviderRole String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  services Service[]

  @@map("service_categories")
}

model ProviderRole {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers Provider[]
  services  Service[]

  @@map("provider_roles")
}

model PaymentMethod {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments        Payment[]
  expenses        Expense[]
  providerPayouts ProviderPayout[]

  @@map("payment_methods")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@map("expense_categories")
}

model ReferralSource {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  channelType String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patients Patient[]

  @@map("referral_sources")
}

// ============================================================================
// CORE TABLES
// ============================================================================

model Family {
  id                  String       @id @default(cuid())
  code                String       @unique
  name                String?
  primaryContactName  String?
  primaryContactPhone String?
  relationToPatients  String?
  areaId              String?
  registrationDate    DateTime     @db.Date
  status              FamilyStatus @default(active)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  area     Area?     @relation(fields: [areaId], references: [id])
  patients Patient[]

  @@index([areaId])
  @@index([status])
  @@map("families")
}

model Patient {
  id               String        @id @default(cuid())
  code             String        @unique
  familyId         String?
  fullName         String
  arabicName       String?
  phone            String
  gender           PatientGender?
  dateOfBirth      DateTime?     @db.Date
  nationalId       String?
  passportNumber   String?
  bloodGroup       BloodGroup?
  maritalStatus    MaritalStatus?
  preferredLanguage Locale?
  religion         String?
  occupation       String?
  insuranceProvider String?
  insuranceMemberId String?
  insurancePolicyNumber String?
  insuranceExpiry  DateTime?     @db.Date
  dnrStatus        DnrStatus?
  areaId           String?
  addressDetail    String?
  landmark         String?
  gpsLatitude      Decimal?      @db.Decimal(10, 7)
  gpsLongitude     Decimal?      @db.Decimal(10, 7)
  addressMapUrl    String?
  handoffGeofenceRadiusMeters Int?
  temporarilyAwayUntil DateTime?
  temporarilyAwayNote String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyContactRelation String?
  registrationDate DateTime      @db.Date @default(now())
  primaryCaregiver String?
  primaryCaregiverPhone String?
  primaryCaregiverWhatsapp String?
  primaryCaregiverEmail String?
  caregiverRelation String?
  chiefComplaint   String?
  referralSourceId String?
  status           PatientStatus @default(new)
  notes            String?
  medplumPatientId String?       @unique
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  family         Family?         @relation(fields: [familyId], references: [id])
  area           Area?           @relation(fields: [areaId], references: [id])
  referralSource ReferralSource? @relation(fields: [referralSourceId], references: [id])
  visits         Visit[]
  carePlans      CarePlan[]
  invoices       Invoice[]
  payments       Payment[]
  nurseShiftAssignments NurseShiftAssignment[]
  userAccount    User?

  @@index([familyId])
  @@index([areaId])
  @@index([status])
  @@index([referralSourceId])
  @@index([phone])
  @@index([nationalId])
  @@index([passportNumber])
  @@map("patients")
}

model Provider {
  id            String              @id @default(cuid())
  code          String              @unique
  fullName      String
  roleId        String
  specialty     String?
  phone         String?
  email         String?
  joiningDate   DateTime            @db.Date
  paymentType   ProviderPaymentType @default(per_visit)
  baseRateEgp   Decimal             @db.Decimal(10, 2)
  commissionPct Decimal?            @db.Decimal(5, 2)
  primaryAreaId String?
  status        ProviderStatus      @default(active)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  role            ProviderRole     @relation(fields: [roleId], references: [id])
  primaryArea     Area?            @relation(fields: [primaryAreaId], references: [id])
  linkedStaff     Staff?           @relation("StaffProviderLink")
  visits          Visit[]
  providerPayouts ProviderPayout[]
  expenses        Expense[]

  @@index([roleId])
  @@index([status])
  @@index([primaryAreaId])
  @@map("providers")
}

model Service {
  id                       String        @id @default(cuid())
  code                     String        @unique
  name                     String
  categoryId               String
  requiredRoleId           String?
  durationMins             Int
  listPriceEgp             Decimal       @db.Decimal(10, 2)
  defaultProviderPayoutEgp Decimal       @db.Decimal(10, 2)
  description              String?
  status                   ServiceStatus @default(active)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  category     ServiceCategory @relation(fields: [categoryId], references: [id])
  requiredRole ProviderRole?   @relation(fields: [requiredRoleId], references: [id])
  visits       Visit[]

  @@index([categoryId])
  @@index([status])
  @@map("services")
}

model Visit {
  id                String      @id @default(cuid())
  code              String      @unique
  patientId         String
  providerId        String?
  serviceId         String
  carePlanId        String?
  bookedDate        DateTime    @db.Date
  scheduledDate     DateTime    @db.Date
  scheduledTime     String?
  completedDatetime DateTime?
  durationActualMin Int?
  status            VisitStatus @default(scheduled)
  areaId            String?
  visitType         VisitType   @default(in_home)
  servicePriceEgp   Decimal     @db.Decimal(10, 2)
  discountEgp       Decimal     @db.Decimal(10, 2) @default(0)
  netPriceEgp       Decimal     @db.Decimal(10, 2)
  providerPayoutEgp Decimal     @db.Decimal(10, 2)
  patientRating     Int?
  bookedBy          String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id])
  provider      Provider?     @relation(fields: [providerId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
  carePlan      CarePlan?     @relation(fields: [carePlanId], references: [id])
  area          Area?         @relation(fields: [areaId], references: [id])
  invoices      Invoice[]
  expenses      Expense[]
  onlineBooking OnlineBooking?

  @@index([patientId])
  @@index([providerId])
  @@index([serviceId])
  @@index([status])
  @@index([scheduledDate])
  @@index([areaId])
  @@index([carePlanId])
  @@map("visits")
}

model CarePlan {
  id                 String         @id @default(cuid())
  code               String         @unique
  patientId          String
  planName           String
  startDate          DateTime       @db.Date
  endDate            DateTime       @db.Date
  totalVisitsPlanned Int
  totalPriceEgp      Decimal        @db.Decimal(10, 2)
  status             CarePlanStatus @default(active)
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  patient  Patient   @relation(fields: [patientId], references: [id])
  visits   Visit[]
  invoices Invoice[]

  @@index([patientId])
  @@index([status])
  @@map("care_plans")
}

model Invoice {
  id               String            @id @default(cuid())
  code             String            @unique
  patientId        String
  invoiceDate      DateTime          @db.Date @default(now())
  linkedType       InvoiceLinkedType
  linkedVisitId    String?
  linkedCarePlanId String?
  grossAmountEgp   Decimal           @db.Decimal(10, 2)
  discountPct      Decimal           @db.Decimal(5, 2) @default(0)
  netAmountEgp     Decimal           @db.Decimal(10, 2)
  dueDate          DateTime?         @db.Date
  status           InvoiceStatus     @default(issued)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  patient        Patient    @relation(fields: [patientId], references: [id])
  linkedVisit    Visit?     @relation(fields: [linkedVisitId], references: [id])
  linkedCarePlan CarePlan?  @relation(fields: [linkedCarePlanId], references: [id])
  payments       Payment[]

  @@index([patientId])
  @@index([status])
  @@index([dueDate])
  @@index([linkedVisitId])
  @@index([linkedCarePlanId])
  @@map("invoices")
}

model Payment {
  id              String   @id @default(cuid())
  code            String   @unique
  invoiceId       String
  patientId       String
  paymentDate     DateTime @db.Date @default(now())
  amountEgp       Decimal  @db.Decimal(10, 2)
  paymentMethodId String
  referenceNumber String?
  receivedBy      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  patient       Patient       @relation(fields: [patientId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([invoiceId])
  @@index([patientId])
  @@index([paymentDate])
  @@map("payments")
}

model Expense {
  id               String   @id @default(cuid())
  code             String   @unique
  expenseDate      DateTime @db.Date
  categoryId       String
  subcategory      String?
  vendorPayee      String?
  amountEgp        Decimal  @db.Decimal(10, 2)
  paymentMethodId  String?
  linkedVisitId    String?
  linkedProviderId String?
  receiptRef       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  paymentMethod   PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  linkedVisit     Visit?          @relation(fields: [linkedVisitId], references: [id])
  linkedProvider  Provider?       @relation(fields: [linkedProviderId], references: [id])

  @@index([categoryId])
  @@index([expenseDate])
  @@index([linkedVisitId])
  @@index([linkedProviderId])
  @@map("expenses")
}

model ProviderPayout {
  id              String   @id @default(cuid())
  code            String   @unique
  providerId      String
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  payoutDate      DateTime @db.Date
  totalVisits     Int
  grossAmountEgp  Decimal  @db.Decimal(10, 2)
  deductionsEgp   Decimal  @db.Decimal(10, 2) @default(0)
  netAmountEgp    Decimal  @db.Decimal(10, 2)
  paymentMethodId String?
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider      Provider       @relation(fields: [providerId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([providerId])
  @@index([payoutDate])
  @@map("provider_payouts")
}

// ============================================================================
// ONLINE BOOKING — Website funnel → converts to Visit
// ============================================================================

model OnlineBooking {
  id                   String              @id @default(cuid())
  bookingRef           String              @unique
  fullName             String
  countryCode          String
  phoneNumber          String
  visitType            OnlineVisitType
  serviceType          OnlineServiceType?
  specialty            String?
  packageType          OnlinePackageType?
  packageDuration      String?
  preferredDate        DateTime?           @db.Date
  timePreference       String?
  sessionCount         String?
  caseType             String?
  nursingType          String?
  nursingHoursPerDay   String?
  nursingDuration      String?
  baseAmountEgp        Decimal             @db.Decimal(10, 2) @default(0)
  discountEgp          Decimal             @db.Decimal(10, 2) @default(0)
  amountEgp            Decimal             @db.Decimal(10, 2)
  currency             String              @default("EGP")
  status               OnlineBookingStatus @default(pending)

  promocodeId          String?
  promocodeCode        String?
  promocode            Promocode?          @relation(fields: [promocodeId], references: [id])

  kashierSessionId     String?
  kashierOrderId       String?
  kashierTransactionId String?
  paymentCompletedAt   DateTime?

  confirmationSentAt   DateTime?

  convertedVisitId     String?  @unique
  convertedAt          DateTime?

  locale               Locale   @default(ar)
  ipAddress            String?
  userAgent            String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  convertedVisit Visit? @relation(fields: [convertedVisitId], references: [id])

  @@index([bookingRef])
  @@index([status])
  @@index([phoneNumber])
  @@index([createdAt])
  @@index([promocodeId])
  @@map("online_bookings")
}

// ============================================================================
// PROMOCODES — Booking discount codes (% or fixed EGP)
// ============================================================================

enum PromocodeKind {
  percentage
  fixed
}

model Promocode {
  id              String        @id @default(cuid())
  code            String        @unique // Stored uppercase; lookups normalise input
  description     String?
  kind            PromocodeKind @default(percentage)
  /// When kind=percentage, value is 0-100. When kind=fixed, value is EGP.
  value           Decimal       @db.Decimal(10, 2)
  /// Optional minimum booking amount before discount applies (EGP).
  minAmountEgp    Decimal?      @db.Decimal(10, 2)
  /// Optional cap on the absolute discount applied (EGP).
  maxDiscountEgp  Decimal?      @db.Decimal(10, 2)
  /// Total redemption cap across all bookings. null = unlimited.
  maxRedemptions  Int?
  redeemedCount   Int           @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookings        OnlineBooking[]

  @@index([isActive, expiresAt])
  @@map("promocodes")
}

// ============================================================================
// PWA PUSH SUBSCRIPTIONS
// ============================================================================

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  locale    Locale   @default(ar)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale])
  @@map("push_subscriptions")
}

// ============================================================================
// STAFF — Admin dashboard users
// ============================================================================

model Staff {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  passwordHash String
  providerId  String?     @unique
  medplumPractitionerId String? @unique
  role        StaffRole   @default(viewer)
  status      StaffStatus @default(active)
  lastLoginAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  provider               Provider? @relation("StaffProviderLink", fields: [providerId], references: [id])
  primaryNurseAssignments NurseShiftAssignment[] @relation("PrimaryNurseAssignments")
  incomingNurseAssignments NurseShiftAssignment[] @relation("IncomingNurseAssignments")
  userAccount            User?

  @@index([email])
  @@index([role])
  @@index([providerId])
  @@index([medplumPractitionerId])
  @@map("staff")
}

model NurseShiftAssignment {
  id                  String  @id @default(cuid())
  patientId           String
  primaryNurseStaffId String
  shiftStartAt        DateTime
  shiftEndAt          DateTime
  status              NurseShiftAssignmentStatus @default(scheduled)
  incomingNurseStaffId String?
  acknowledgedAt      DateTime?
  escalationTaskId    String?
  notes               String?
  createdByStaffId    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  patient        Patient @relation(fields: [patientId], references: [id])
  primaryNurse   Staff   @relation("PrimaryNurseAssignments", fields: [primaryNurseStaffId], references: [id])
  incomingNurse  Staff?  @relation("IncomingNurseAssignments", fields: [incomingNurseStaffId], references: [id])

  @@index([patientId, shiftStartAt])
  @@index([primaryNurseStaffId, shiftStartAt])
  @@index([incomingNurseStaffId, acknowledgedAt])
  @@map("nurse_shift_assignments")
}

// ============================================================================
// DOCTORS — Bilingual provider profiles (migrated from JSON)
// ============================================================================

model Doctor {
  id                    Int      @id
  slug                  String   @unique
  image                 String
  rating                Float
  gender                String
  location              String
  experienceYears       Int
  successRate           String
  avgWaitTime           String
  totalPatients         String
  availabilityStatus    String
  availabilityBadgeClass String
  specialityColorClass  String
  specialityTextClass   String
  duration              String
  channels              Json
  languages             Json
  clinics               Json
  areaCoverage          Json
  clinicDetails         Json
  testimonials          Json
  workHistory           Json?

  // Pricing (stored as strings to match existing format e.g. "EGP 1500" / "N/A")
  priceTelemedicine     String
  priceHomeVisit        String
  priceClinicVisit      String
  consultationFee       String
  maxConsultationFee    String

  // English content
  nameEn                String
  specialityEn          String
  professionalTitleEn   String
  bioEn                 String?
  certificationsEn      Json
  educationEn           Json

  // Arabic content
  nameAr                String
  specialityAr          String
  professionalTitleAr   String
  bioAr                 String?
  certificationsAr      Json
  educationAr           Json

  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([slug])
  @@index([specialityEn])
  @@index([isActive])
  @@map("doctors")
}

// ============================================================================
// AUDIT LOG — Full history of every record change
// ============================================================================

model AuditLog {
  id            String      @id @default(cuid())
  tableName     String
  recordId      String
  action        AuditAction
  changedFields Json?
  previousData  Json?
  newData       Json?
  changedBy     String?
  changedAt     DateTime    @default(now())

  @@index([tableName, recordId])
  @@index([changedAt])
  @@index([changedBy])
  @@map("audit_logs")
}

// ============================================================================
// BOOKING PRICES — All service prices editable from DB (no code deploy needed)
// ============================================================================

model BookingPrice {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "telemedicine", "homeVisit:doctorVisit"
  label     String           // Human-readable for admin display
  priceEgp  Int
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("booking_prices")
}

// ============================================================================
// SPECIALTIES — Medical specialties with bilingual names
// ============================================================================

model Specialty {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "geriatrics", "cardiology"
  nameEn    String
  nameAr    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  @@index([isActive, sortOrder])
  @@map("specialties")
}

// ============================================================================
// CONTENT SERVICES — Services shown on the /services marketing page
// ============================================================================

model ContentService {
  id          String   @id @default(cuid())
  code        String   @unique // matches translation key, e.g. "doctorVisits"
  iconClass   String           // e.g. "isax isax-health"
  landingSlug String?          // e.g. "doctor-at-home" — null if no landing page
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  @@map("content_services")
}

// ============================================================================
// RATE LIMIT — Fixed-window counters backing the rate-limit helper
// ============================================================================

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "booking-create:1.2.3.4"
  count       Int      @default(0)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@map("rate_limits")
}

// ============================================================================
// COVERAGE CHECK — Every map/form coverage query for analytics
// ============================================================================

model CoverageCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  latitude  Float
  longitude Float
  covered   Boolean
  areaName  String?
  ipHash    String?  // SHA-256 prefix of visitor IP — no PII stored
  userAgent String?

  @@index([createdAt])
  @@index([covered])
  @@index([areaName])
  @@map("coverage_checks")
}

// ============================================================================
// AUTH — NextAuth v5 (Auth.js). User is the auth identity.
//   - role=patient → links to Patient record via patientId
//   - role=staff   → links to Staff record via staffId
// JWT strategy: no Session table needed. Account is for OAuth only.
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(patient)
  patientId     String?   @unique
  staffId       String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient  Patient? @relation(fields: [patientId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])
  accounts Account[]

  @@index([role])
  @@index([phone])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
