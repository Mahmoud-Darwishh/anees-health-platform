    "ehr:scan:tick": "node scripts/trigger-document-scan.cjs",
    "goals:backfill:fhir": "node scripts/run-backfill-patient-goals-to-fhir.cjs",
    "ehr:audit-gap": "node -r ts-node/register scripts/ehr-audit-gap-report.ts",
    "db:push": "prisma db push",
    "db:push:unsafe": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:doctors": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-doctors.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1062.0",
