    "@medplum/core": "^5.1.13",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.16.0",
    "next": "^16.1.0",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.6.0",
    "prisma": "^5.22.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-slick": "^0.31.0",
    "sass": "^1.96.0",
    "slick-carousel": "^1.8.1",
    "ts-node": "^10.9.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-slick": "^0.23.13",
    "@types/sharp": "^0.31.1",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
