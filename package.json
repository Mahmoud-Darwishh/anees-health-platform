{
  "name": "anees-health-platform",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.18.0 <23 || >=24.2.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "lint:css": "node scripts/guard-logical-css.cjs",
    "lint:css:list": "node scripts/guard-logical-css.cjs --list",
    "lint:css:update": "node scripts/guard-logical-css.cjs --update",
    "lint:color": "node scripts/guard-hardcoded-color.cjs",
    "lint:color:list": "node scripts/guard-hardcoded-color.cjs --list",
    "lint:color:update": "node scripts/guard-hardcoded-color.cjs --update",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:tenant": "node scripts/guard-tenant-scope.cjs",
    "ci:migration-guard": "node scripts/prisma-migration-guard.cjs",
    "test:security-policy": "ts-node --transpile-only --project scripts/tsconfig.json scripts/security-policy-selftest.cjs",
    "audit:verify-chain": "ts-node --transpile-only --project scripts/tsconfig.json scripts/verify-audit-chain.ts",
    "test:glucose-profile": "ts-node --transpile-only --project scripts/tsconfig.json scripts/glucose-profile-selftest.cjs",
    "lint:rbac": "ts-node --transpile-only --project scripts/tsconfig.json scripts/lint-rbac.ts",
    "lint:rbac:fix": "ts-node --transpile-only --project scripts/tsconfig.json scripts/lint-rbac.ts --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "docs:migrate:r2": "node -r ts-node/register scripts/migrate-medplum-binaries-to-r2.ts",
    "ehr:scan:tick": "node scripts/trigger-document-scan.cjs",
    "goals:backfill:fhir": "node scripts/run-backfill-patient-goals-to-fhir.cjs",
    "ehr:audit-gap": "ts-node --transpile-only --project scripts/tsconfig.json scripts/ehr-audit-gap-report.ts",
    "ehr:audit-backfill": "ts-node --transpile-only --project scripts/tsconfig.json scripts/ehr-audit-backfill.ts",
    "db:push": "node scripts/guard-db-push.cjs && prisma db push",
    "db:push:unsafe": "node scripts/guard-db-push.cjs --allow-prod && prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:doctors": "ts-node --project scripts/tsconfig.json prisma/seed-doctors.ts",
    "db:seed:icd10": "ts-node --transpile-only --project scripts/tsconfig.json prisma/seed-icd10.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --project scripts/tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@medplum/core": "^5.1.26",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.65.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.2",
    "prisma": "^5.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-slick": "^0.31.0",
    "sass": "^1.101.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-slick": "^0.23.13",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "sharp": "^0.35.3",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "eslint-plugin-react-hooks": "7.0.1"
  }
}
