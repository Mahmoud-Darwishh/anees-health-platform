{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Africa/Cairo",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Auto-merge low-risk lockfile-only patch, pin, and digest updates",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Hold major upgrades of data/auth-critical packages for manual review",
      "matchPackageNames": [
        "prisma",
        "@prisma/client",
        "next",
        "next-auth",
        "react",
        "react-dom",
        "@medplum/core"
      ],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  }
}
