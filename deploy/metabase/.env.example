# =============================================================================
# Anees Health · Metabase · /opt/metabase/.env  (copy to `.env`, chmod 600)
# =============================================================================
# Generate BOTH values with:  openssl rand -base64 32
# Do NOT commit the real .env. The encryption key must ALSO be escrowed in your
# password manager — if it is lost, Metabase cannot decrypt the data-source
# credentials it stores and you must re-enter them.
# =============================================================================

# Password for Metabase's OWN metadata Postgres container (not the app DB).
MB_DB_PASS=__generate_with_openssl_rand_base64_32__

# Encrypts the connection secrets Metabase stores at rest (AES-256).
MB_ENCRYPTION_SECRET_KEY=__generate_with_openssl_rand_base64_32__
